<Window x:Class="DemoExz22.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExz22"
        mc:Ignorable="d"
        Style="{StaticResource Windows}"
        Title="Products" Height="800" Width="1200">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid HorizontalAlignment="Left" Name="AdminPanel">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin=" 20 0" Grid.Column="0">
                <TextBlock Text="Search"/>
                <TextBox Name="SearchTextBox" Width="200" TextChanged="SearchTextBox_TextChanged"/>
            </StackPanel>
            <StackPanel Margin=" 20 0" Grid.Column="1">
                <TextBlock Text="Sort"/>
                <ComboBox Name="SortComboBox" Width="200" SelectionChanged="SortComboBox_SelectionChanged"/>
            </StackPanel>
            <StackPanel Margin=" 20 0" Grid.Column="2">
                <TextBlock Text="Filter"/>
                <ComboBox Name="FilterComboBox" Width="200" SelectionChanged="FilterComboBox_SelectionChanged"/>
            </StackPanel>

        </Grid>

        <TextBlock Name ="FullUserName" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20,10"/>

        <ScrollViewer Grid.Row="1">
            <ItemsControl Name="ProductList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="10" Tag="{Binding ID}" Background="{Binding Background}" MouseDown="Border_MouseDown">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="80" Height="80" Margin="15, 0">
                                    <Image Source="{Binding Photo}"/>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="SemiBold">
                                        <Run Text="{Binding Category.Name}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Description: "/>
                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Supplier: "/>
                                        <TextBlock Text="{Binding Supplier.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Manufacturer: "/>
                                        <TextBlock Text="{Binding Manufacturer.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Pice: "/>
                                        <TextBlock Text="{Binding Price, StringFormat=C2}"/>
                                        <TextBlock Text="  "/>
                                        <TextBlock Text="{Binding OldPrice, StringFormat=C2}" Foreground="Red" TextDecorations="Strikethrough"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Unit: "/>
                                        <TextBlock Text="{Binding Unit.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Quantity: "/>
                                        <TextBlock Text="{Binding Quantity}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="2">
                                    <StackPanel>
                                        <TextBlock Text="Discount: "/>
                                        <TextBlock Text="{Binding Discount, StringFormat={}{0}%}"/>
                                        <Button Content="Удалить" Name="DeleteButton" Margin="0,10,0,0" Tag="{Binding ID}" Click="DeleteButton_Click" Visibility="{Binding AdminButtonsVisibility}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Name ="LogoutButton" Content="Logout" Click="LogoutButton_Click" Grid.Row="2" Margin="20, 0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
        <Button Name ="CreateButton" Content="Create" Click="CreateButton_Click" Grid.Row="2" Margin="1122,0,0,10" VerticalAlignment="Bottom" HorizontalAlignment="Left" Visibility="Collapsed"/>



    </Grid>
</Window>
