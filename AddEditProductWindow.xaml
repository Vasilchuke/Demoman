<Window x:Class="DemoExz22.AddEditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DemoExz22"
        mc:Ignorable="d"
        Style="{StaticResource Windows}"
        Title="Редактирование продукта" Height="750" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <ScrollViewer>
            <StackPanel Margin="20 0">
                <TextBlock Text="Article"/>
                <TextBox x:Name="ProductArticle" MaxLength="10"/>
                <TextBlock Text="Name"/>
                <TextBox x:Name="ProductName" MaxLength="30"/>
                <TextBlock Text="Unit"/>
                <ComboBox x:Name="ProductUnit"/>
                <TextBlock Text="Price"/>
                <TextBox x:Name="ProductPrice"/>
                <TextBlock Text="Supplier"/>
                <ComboBox x:Name="ProductSupplier"/>
                <TextBlock Text="Manufacturer"/>
                <ComboBox x:Name="ProductManufacturer"/>
                <TextBlock Text="Category"/>
                <ComboBox x:Name="ProductCategory"/>
                <TextBlock Text="Discount"/>
                <TextBox x:Name="ProductDiscount"/>
                <TextBlock Text="Quantity"/>
                <TextBox x:Name="ProductQuantity"/>
                <TextBlock Text="Description"/>
                <TextBox x:Name="ProductDescription" Height="150" TextWrapping="Wrap"/>
                <TextBlock Text="Photo"/>
                <TextBox x:Name="ProductPhoto"/>
            </StackPanel>
        </ScrollViewer>

        <Button Name="CancelButton" Content="Cancel" Click="CancelButton_Click" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20 0"/>
        <Button Name="SaveButton" Content="Save" Click="SaveButton_Click" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20 0"/>

    </Grid>
</Window>
